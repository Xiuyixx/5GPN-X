log:
  level: info

plugins:
  - tag: gfw_domains
    type: domain_set
    args:
      files:
        - /etc/mosdns/gfwlist.txt

  - tag: china_domains
    type: domain_set
    args:
      files:
        - /etc/mosdns/chinalist.txt

  - tag: remote_primary
    type: forward
    args:
      concurrent: 2
      upstreams:
__REMOTE_PRIMARY_UPSTREAMS__

  - tag: remote_secondary
    type: forward
    args:
      concurrent: 2
      upstreams:
__REMOTE_SECONDARY_UPSTREAMS__

  # China DNS race: concurrent query to all 4 domestic resolvers over UDP.
  - tag: local_primary_forward
    type: forward
    args:
      concurrent: 4
      upstreams:
__LOCAL_PRIMARY_UPSTREAMS__

  # China DNS TCP fallback: used when UDP race times out.
  - tag: local_secondary_forward
    type: forward
    args:
      concurrent: 4
      upstreams:
__LOCAL_SECONDARY_UPSTREAMS__

  # Overseas fallback for China DNS: activated when both UDP and TCP domestic
  # DNS fail.  Includes 22.22.22.22 as a built-in resilience address.
  - tag: local_overseas_fallback_forward
    type: forward
    args:
      concurrent: 3
      upstreams:
        - addr: 1.1.1.1:53
        - addr: 8.8.8.8:53
        - addr: 22.22.22.22:53

  - tag: local_primary
    type: sequence
    args:
      - exec: ecs 139.226.48.1
      - exec: $local_primary_forward

  - tag: local_secondary
    type: sequence
    args:
      - exec: ecs 139.226.48.1
      - exec: $local_secondary_forward

  - tag: local_overseas_fallback
    type: sequence
    args:
      - exec: $local_overseas_fallback_forward

  - tag: remote_fallback
    type: fallback
    args:
      primary: remote_primary
      secondary: remote_secondary
      threshold: 1000
      always_standby: true

  # China DNS: UDP race -> 150ms timeout -> TCP race -> overseas fallback.
  - tag: local_udp_tcp_fallback
    type: fallback
    args:
      primary: local_primary
      secondary: local_secondary
      threshold: 150
      always_standby: true

  - tag: local_fallback
    type: fallback
    args:
      primary: local_udp_tcp_fallback
      secondary: local_overseas_fallback
      threshold: 800
      always_standby: true

  - tag: remote_cache
    type: cache
    args:
      size: __CACHE_SIZE__
      lazy_cache_ttl: 300

  - tag: local_cache
    type: cache
    args:
      size: __CACHE_SIZE__
      lazy_cache_ttl: 300

  - tag: remote_resolve
    type: sequence
    args:
      - exec: $remote_cache
      - exec: $remote_fallback

  - tag: local_resolve
    type: sequence
    args:
      - exec: $local_cache
      - exec: $local_fallback

  # DNS service does not return AAAA records; clients use IPv4 only.
  # Internal clients: GFWList -> server IP; ChinaList -> local_resolve;
  #                   other -> server IP (all proxied via TCP/QUIC).
  # External clients: GFWList -> normal overseas resolve (no hijack);
  #                   ChinaList -> local_resolve; other -> overseas.
  - tag: reject_aaaa
    type: sequence
    args:
      - matches:
          - qtype 28
        exec: reject 0

  - tag: private_client
    type: sequence
    args:
      - matches:
          - qtype 1
          - qname $gfw_domains
        exec: black_hole __SERVER_IP__
      - matches:
          - has_resp
        exec: accept
      - matches:
          - qname $china_domains
        exec: goto local_resolve
      - matches:
          - qtype 1
        exec: black_hole __SERVER_IP__
      - matches:
          - has_resp
        exec: accept
      - exec: goto remote_resolve

  - tag: public_client
    type: sequence
    args:
      - matches:
          - qname $china_domains
        exec: goto local_resolve
      - exec: goto remote_resolve

  - tag: main_sequence
    type: sequence
    args:
      - exec: $reject_aaaa
      - matches:
          - has_resp
        exec: accept
      - matches:
          - client_ip 172.22.0.0/16
        exec: goto private_client
      - exec: goto public_client

  - tag: udp_53
    type: udp_server
    args:
      entry: main_sequence
      listen: "0.0.0.0:53"

  - tag: tcp_53
    type: tcp_server
    args:
      entry: main_sequence
      listen: "0.0.0.0:53"

  - tag: dot_853
    type: tcp_server
    args:
      entry: main_sequence
      listen: "0.0.0.0:853"
      cert: /etc/mosdns/certs/fullchain.pem
      key: /etc/mosdns/certs/privkey.pem
